# ── Apify API ─────────────────────────────────────────────────────────────
# Sign up at https://apify.com (personal email fine, no business email needed)
# Free tier: $5/month in compute credits — enough for ~1,000 searches/month
# Get your token: Apify Console → Settings → Integrations → API tokens
APIFY_TOKEN=your_apify_token_here

# ── Your local stores (pre-filled for Melbourne FL) ───────────────────────
# Costco Viera West — 4305 Pineda Causeway, Melbourne FL 32940
# Warehouse ID: from costco.com/warehouse-locations/melbourne-fl-1450.html
COSTCO_WAREHOUSE_ID=1450

# Sam's Club Melbourne — 4255 W New Haven Ave, Melbourne FL 32904
# Club ID: from samsclub.com/club/8141-melbourne-fl
SAMS_CLUB_ID=8141

# Port (Railway sets this automatically)
PORT=3001

# ── How to find IDs for a different store ─────────────────────────────────
# Costco: costco.com → Find a Warehouse → click your store → ID is in the URL
#   e.g. costco.com/warehouse-locations/your-city-fl-XXXX.html → XXXX
#
# Sam's Club: samsclub.com → Find a Club → click your club → ID is in the URL
#   e.g. samsclub.com/club/XXXX-your-city-fl → XXXX
